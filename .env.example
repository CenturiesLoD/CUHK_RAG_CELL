# Copy this file to .env on the runtime host and adjust paths as needed.
# Do not commit real API keys or mentor demo keys.

# OpenAI-compatible answer model endpoint.
# The CCI demo uses local vLLM on localhost.
LUOSS_BASE_URL=http://127.0.0.1:8000/v1
LUOSS_MODEL=qwen3-32b
LUOSS_API_KEY=

# Combined RAG artifacts.
RAG_CHUNKS_PATH=chunks/rag_chunks.jsonl
RAG_ALIASES_PATH=processed/rag_aliases.jsonl
RAG_MODEL_PATH=models/Qwen3-Embedding-8B
RAG_EMBEDDINGS_PATH=embeddings/rag_qwen3_embedding_8b.npz
RAG_METADATA_PATH=embeddings/rag_qwen3_embedding_8b.metadata.json

# Vector backend.
RAG_VECTOR_BACKEND=faiss
RAG_FAISS_INDEX_PATH=embeddings/rag_qwen3_embedding_8b.ivfflat.faiss
RAG_FAISS_CANDIDATES=4096
RAG_FAISS_NPROBE=64

# Optional neural reranker.
RAG_RERANKER_ENABLED=true
RAG_RERANKER_MODEL_PATH=models/ms-marco-MiniLM-L-6-v2
RAG_RERANKER_CANDIDATES=48
RAG_RERANKER_WEIGHT=0.35
RAG_RERANKER_EXACT_MATCH_WEIGHT=0.0
RAG_RERANKER_MAX_LENGTH=512
RAG_RERANKER_BATCH_SIZE=8

# Local service ports.
LLM_HOST=127.0.0.1
LLM_PORT=8000
RAG_HOST=127.0.0.1
RAG_PORT=8010
MENTOR_API_HOST=127.0.0.1
MENTOR_API_PORT=8020
MENTOR_RAG_BASE_URL=http://127.0.0.1:8010

# Set this before exposing the mentor API beyond localhost.
MENTOR_API_KEY=
MENTOR_MAX_TOP_K=10
MENTOR_MAX_SOURCE_TEXT_CHARS=700
MENTOR_RAG_TIMEOUT_SECONDS=300

# vLLM startup defaults.
LLM_MODEL_PATH=models/Qwen3-32B
LLM_MODEL_SOURCE_PATH=models/Qwen3-32B
LLM_FAST_MODEL_CACHE_ENABLED=false
LLM_FAST_MODEL_CACHE_PATH=/dev/shm/cell_rag_models/Qwen3-32B
LLM_SERVED_MODEL_NAME=qwen3-32b
LLM_CUDA_VISIBLE_DEVICES=0
LLM_MAX_MODEL_LEN=4096
LLM_MAX_NUM_SEQS=1
LLM_GPU_MEMORY_UTILIZATION=0.90
LLM_CPU_OFFLOAD_GB=0
LLM_SAFETENSORS_LOAD_STRATEGY=prefetch
LLM_SAFETENSORS_PREFETCH_NUM_THREADS=4
LLM_ENFORCE_EAGER=false

# RAG embedding/reranker GPU selection.
RAG_CUDA_VISIBLE_DEVICES=1
